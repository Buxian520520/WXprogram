/**
 * AI 对话窗口组件样式
 */

/* ===== 根 / 遮罩 / 面板容器 ===== */
.fp-root {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  z-index: 9990;
  pointer-events: none;
}

.fp-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 9991;
  pointer-events: auto;
  animation: fp-fadeIn 0.25s ease;
}

@keyframes fp-fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.fp-panel {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: 50vw;
  min-width: 520rpx;
  background: #fff;
  z-index: 9992;
  display: flex;
  flex-direction: column;
  box-shadow: -6rpx 0 32rpx rgba(0, 0, 0, 0.18);
  border-radius: 24rpx 0 0 24rpx;
  pointer-events: auto;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.fp-panel.fp-open {
  transform: translateX(0);
  z-index: 9999;
}

/* ===== 头部 ===== */
.fp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 22rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fp-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1D2129;
}

.fp-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fp-action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

.fp-action-btn:active {
  background: #e8e8e8;
}

.fp-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.fp-close:active {
  background: #e8e8e8;
}

/* ===== 消息列表 ===== */
.fp-chat-body {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  background: #f9fafb;
}

.chat-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.chat-empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.chat-empty-text {
  font-size: 28rpx;
  color: #ccc;
}

/* ===== 消息项 ===== */
.chat-msg-wrapper {
  margin-bottom: 24rpx;
}

.chat-msg {
  display: flex;
  flex-direction: column;
}

.msg-user {
  align-items: flex-end;
}

.msg-assistant {
  align-items: flex-start;
}

/* ===== 气泡 ===== */
.msg-bubble {
  max-width: 90%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  word-break: break-all;
  white-space: pre-wrap;
}

.bubble-user {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-assistant {
  background: #fff;
  color: #1D2129;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 时间 ===== */
.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 6rpx;
  padding: 0 8rpx;
}

.time-right {
  text-align: right;
}

.time-left {
  text-align: left;
}

/* ===== 打字动画 ===== */
.typing-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 22rpx 28rpx;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  background: #ccc;
  border-radius: 50%;
  animation: typingBounce 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-12rpx); opacity: 1; }
}

/* ===== 输入栏 ===== */
.fp-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
  flex-shrink: 0;
}

.fp-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 38rpx;
  font-size: 28rpx;
}

.fp-send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 76rpx;
  background: #e8e8e8;
  color: #999;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.fp-send-btn.send-active {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
}

.fp-send-btn.send-disabled {
  opacity: 0.6;
}

/* ===== 触发按钮 ===== */
.fp-trigger {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 24rpx 0 0 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: -4rpx 4rpx 20rpx rgba(22, 119, 255, 0.35);
  pointer-events: auto;
  z-index: 9989;
  overflow: hidden;
}

.fp-trigger-main {
  width: 100%;
  padding: 14rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fp-trigger-main:active {
  background: rgba(255, 255, 255, 0.15);
}

.fp-trigger-icon {
  font-size: 36rpx;
}

.fp-trigger-close {
  width: 100%;
  padding: 8rpx 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.25);
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.fp-trigger-close:active {
  background: rgba(255, 0, 0, 0.2);
}
