<view class="empty-container">
  <view class="empty-icon">{{icon}}</view>
  <view class="empty-title">{{title}}</view>
  <view wx:if="{{description}}" class="empty-desc">{{description}}</view>
  <view wx:if="{{showButton}}" class="empty-action">
    <button class="btn btn-primary btn-sm" bindtap="onAction">{{buttonText}}</button>
  </view>
</view>
