.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 98rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 2rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
}

.text-active {
  color: #1677FF;
}
