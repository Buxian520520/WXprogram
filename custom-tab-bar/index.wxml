<cover-view class="tab-bar">
  <cover-view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <cover-image
      class="tab-icon"
      src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
    ></cover-image>
    <cover-view class="tab-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
