<block wx:if="{{!tabBarHidden}}">
  <view class="tab-bar">
    <view
      wx:for="{{list}}"
      wx:key="index"
      class="tab-item"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <image
        class="tab-icon {{selected === index ? 'icon-active' : ''}}"
        src="{{item.iconPath}}"
      ></image>
      <view class="tab-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</view>
    </view>
  </view>
</block>
