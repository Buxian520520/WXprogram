/**
 * 学生表单页样式
 */

.page-container {
  padding-top: 88rpx;
  padding-bottom: 40rpx;
}

/* ===== 头像区 ===== */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  background: #fff;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx dashed #d9d9d9;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.avatar-icon {
  font-size: 40rpx;
}

.avatar-hint {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ===== 表单区 ===== */
.form-section {
  background: #fff;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.form-section .form-group {
  margin-bottom: 28rpx;
}

.form-section .form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.form-section .form-input,
.form-section .picker {
  height: 84rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 28rpx;
}

.form-section .form-input:focus {
  border-color: #1677FF;
  background: #fff;
}

.input-disabled {
  color: #999 !important;
  background: #f5f5f5 !important;
}

/* ===== 提交区 ===== */
.submit-section {
  padding: 0 24rpx;
  display: flex;
}

.submit-section .btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  align-items: center;
}
