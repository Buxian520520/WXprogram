/**
 * 讲师信息页样式
 */

/* ===== 自定义导航栏 ===== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: #1677FF;
  color: #fff;
  z-index: 100;
  box-sizing: border-box;
}

.nav-back {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  padding: 8rpx 16rpx 8rpx 0;
}

.nav-back-icon {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
}

.nav-placeholder {
  width: 80rpx;
}

.page-container {
  padding-top: 88rpx;
  padding-bottom: 40rpx;
}

/* ===== 模式栏 ===== */
.mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.mode-label {
  font-size: 28rpx;
  color: #666;
}

/* ===== 头像 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid #f0f0f0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e6f4ff;
}

.avatar-icon {
  font-size: 60rpx;
}

.avatar-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #1677FF;
}

/* ===== 表单 ===== */
.form-section {
  background: #fff;
  padding: 24rpx;
}

.form-section .form-group {
  margin-bottom: 24rpx;
}

.form-section .form-input,
.form-section .picker,
.form-section .form-textarea {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 28rpx;
}

.form-section .form-input,
.form-section .picker {
  height: 84rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
}

.form-section .form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.input-disabled {
  color: #999 !important;
  background: #f5f5f5 !important;
}

/* ===== 提交 ===== */
.submit-section {
  padding: 24rpx;
  display: flex;
  
}

.submit-section .btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}
