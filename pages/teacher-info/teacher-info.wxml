<!--
  讲师信息页
  查看和编辑当前教师的个人信息
-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">←</text>
      <text>返回</text>
    </view>
    <view class="nav-title">讲师信息</view>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 模式切换 -->
  <view class="mode-bar">
    <text class="mode-label">{{isEdit ? '编辑模式' : '查看模式'}}</text>
    <button
      class="btn {{isEdit ? 'btn-outline' : 'btn-primary'}} btn-sm"
      bindtap="toggleEdit"
    >{{isEdit ? '取消编辑' : '编辑信息'}}</button>
  </view>

  <!-- 头像 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="{{isEdit ? 'chooseAvatar' : ''}}">
      <image
        wx:if="{{form.avatarUrl}}"
        src="{{form.avatarUrl}}"
        mode="aspectFill"
        class="avatar-img"
      />
      <view wx:else class="avatar-placeholder">
        <text class="avatar-icon">👨‍🏫</text>
      </view>
    </view>
    <text wx:if="{{isEdit}}" class="avatar-hint">点击更换头像</text>
  </view>

  <!-- 信息表单 -->
  <view class="form-section">
    <!-- 工号 -->
    <view class="form-group">
      <view class="form-label">工号</view>
      <view class="form-input input-disabled">{{form.teacherNo || '-'}}</view>
    </view>

    <!-- 姓名 -->
    <view class="form-group">
      <view class="form-label">姓名 <text class="required">*</text></view>
      <input
        class="form-input {{isEdit ? '' : 'input-disabled'}}"
        placeholder="请输入姓名"
        value="{{form.name}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="name"
      />
      <view wx:if="{{errors.name}}" class="form-error">{{errors.name}}</view>
    </view>

    <!-- 性别 -->
    <view class="form-group">
      <view class="form-label">性别</view>
      <picker
        wx:if="{{isEdit}}"
        mode="selector"
        range="{{genderOptions}}"
        value="{{genderIndex}}"
        bindchange="onGenderChange"
      >
        <view class="picker">{{form.gender || '请选择'}}</view>
      </picker>
      <view wx:else class="form-input input-disabled">{{form.gender || '-'}}</view>
    </view>

    <!-- 年龄 -->
    <view class="form-group">
      <view class="form-label">年龄</view>
      <input
        class="form-input {{isEdit ? '' : 'input-disabled'}}"
        type="number"
        placeholder="请输入年龄"
        value="{{form.age}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="age"
      />
    </view>

    <!-- 手机 -->
    <view class="form-group">
      <view class="form-label">手机号码</view>
      <input
        class="form-input {{isEdit ? '' : 'input-disabled'}}"
        type="number"
        placeholder="请输入手机号码"
        value="{{form.mobile}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="mobile"
        maxlength="11"
      />
      <view wx:if="{{errors.mobile}}" class="form-error">{{errors.mobile}}</view>
    </view>

    <!-- 邮箱 -->
    <view class="form-group">
      <view class="form-label">邮箱</view>
      <input
        class="form-input {{isEdit ? '' : 'input-disabled'}}"
        placeholder="请输入邮箱"
        value="{{form.email}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="email"
      />
      <view wx:if="{{errors.email}}" class="form-error">{{errors.email}}</view>
    </view>

    <!-- 部门 -->
    <view class="form-group">
      <view class="form-label">所属部门</view>
      <input
        class="form-input {{isEdit ? '' : 'input-disabled'}}"
        placeholder="请输入部门"
        value="{{form.department}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="department"
      />
    </view>

    <!-- 职称 -->
    <view class="form-group">
      <view class="form-label">职称</view>
      <picker
        wx:if="{{isEdit}}"
        mode="selector"
        range="{{titleOptions}}"
        value="{{titleIndex}}"
        bindchange="onTitleChange"
      >
        <view class="picker">{{form.title || '请选择'}}</view>
      </picker>
      <view wx:else class="form-input input-disabled">{{form.title || '-'}}</view>
    </view>

    <!-- 入职日期 -->
    <view class="form-group">
      <view class="form-label">入职日期</view>
      <picker
        wx:if="{{isEdit}}"
        mode="date"
        value="{{form.hireDate}}"
        end="{{today}}"
        bindchange="onHireDateChange"
      >
        <view class="picker">{{form.hireDate || '请选择'}}</view>
      </picker>
      <view wx:else class="form-input input-disabled">{{form.hireDate || '-'}}</view>
    </view>

    <!-- 个人简介 -->
    <view class="form-group">
      <view class="form-label">个人简介</view>
      <textarea
        class="form-textarea {{isEdit ? '' : 'input-disabled'}}"
        placeholder="请输入个人简介"
        value="{{form.description}}"
        disabled="{{!isEdit}}"
        bindinput="onFieldChange"
        data-field="description"
        maxlength="500"
      ></textarea>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view wx:if="{{isEdit}}" class="submit-section">
    <button class="btn btn-primary btn-block" bindtap="saveInfo" loading="{{loading}}">保存修改</button>
  </view>
</view>
