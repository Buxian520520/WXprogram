/**
 * 个人中心页样式
 */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: 88rpx;
  padding-bottom: 120rpx;
}

/* ===== 头部 ===== */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #1677FF, #69b1ff);
  margin-bottom: 24rpx;
}

.avatar-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 3rpx solid rgba(255,255,255,0.5);
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.header-info {
  flex: 1;
}

.header-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-role .tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.3);
  color: #fff;
}

/* ===== 菜单区 ===== */
.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

.menu-value {
  font-size: 24rpx;
  color: #999;
}

/* ===== 退出 ===== */
.logout-section {
  padding: 40rpx 24rpx;
  display: flex;
  align-self: center;
}

.logout-section .btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}
.btn-block{
  align-items: center;
}
