/**
 * 登录页样式
 */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1677FF 0%, #69b1ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: calc(88rpx + 60rpx) 40rpx 60rpx;
}

/* ===== Header ===== */
.login-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.login-logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* ===== 模式切换 ===== */
.mode-tabs {
  display: flex;
  width: 100%;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 36rpx;
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
  transition: all 0.3s;
}

.mode-tab-active {
  background: #fff;
  color: #1677FF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

/* ===== 表单卡片 ===== */
.form-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

/* ===== 角色选择器 ===== */
.role-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.role-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  
}

.role-btn-active {
  background: #e6f4ff;
  color: #1677FF;
  border-color: #1677FF;
  font-weight: 600;
}

/* ===== 表单字段（复用全局样式并覆盖） ===== */
.form-card .form-input {
  background: #f7f8fa;
  border-color: #e8e8e8;
  height: 88rpx;
}

.form-card .form-input:focus {
  background: #fff;
  border-color: #1677FF;
}

.form-card .picker {
  background: #f7f8fa;
  border-color: #e8e8e8;
  height: 88rpx;
}

.form-card .form-label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.form-card .btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* ===== 切换提示 ===== */
.switch-hint {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #999;
}

/* ===== 消息条 ===== */
.message-bar {
  position: fixed;
  top: 88rpx;
  left: 40rpx;
  right: 40rpx;
  padding: 24rpx 32rpx;
  border-radius: 0 0 16rpx 16rpx;
  font-size: 28rpx;
  text-align: center;
  z-index: 1000;
  animation: slideDown 0.3s ease;
}

.message-bar.error {
  background: #fff0f0;
  color: #F53F3F;
  border: 1rpx solid #ffccc7;
}

.message-bar.success {
  background: #e8ffea;
  color: #00B42A;
  border: 1rpx solid #b7eb8f;
}

@keyframes slideDown {
  from { transform: translateY(-100%); }
  to { transform: translateY(0); }
}
.mt-lg {
  margin-top: var(--spacing-lg);
  display: flex;
}

/* 按钮 loading 态（替代原生 loading 属性，避免闪烁） */
.form-card .btn[disabled] {
  opacity: 0.7;
}

/* ===== 密码显示切换 ===== */
.pwd-toggle {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.pwd-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.2s;
}

.pwd-checkbox.checked {
  background: #1677FF;
  border-color: #1677FF;
}

.pwd-toggle-text {
  font-size: 26rpx;
  color: #666;
}
