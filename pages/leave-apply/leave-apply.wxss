/**
 * 学生请假页样式
 */

.page-container {
  padding-top: 88rpx;
  padding-bottom: 120rpx;
}

/* ===== 表单卡片 ===== */
.form-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.toggle-btn {
  font-size: 24rpx;
  color: #1677FF;
  font-weight: 400;
}

/* ===== 表单字段 ===== */
.form-card .form-group {
  margin-bottom: 24rpx;
}

.form-card .picker,
.form-card .form-textarea {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
}

.form-card .picker {
  height: 80rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.form-card .form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ===== 记录卡片 ===== */
.record-card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.filter-text {
  font-size: 24rpx;
  color: #1677FF;
  font-weight: 400;
}

/* ===== 记录项 ===== */
.leave-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.leave-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.item-body {
  margin-bottom: 4rpx;
}

.item-body text {
  font-size: 24rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.item-footer text {
  font-size: 22rpx;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.action-link {
  color: #1677FF;
  font-size: 24rpx;
}

.action-delete {
  color: #F53F3F;
}

/* 分页内嵌 */
.record-card .pagination {
  padding: 20rpx 0 0;
  background: transparent;
  border: none;
}

/* ===== 对话框 ===== */
.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-box {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.dialog-title {
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-body {
  padding: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.dialog-footer {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-row {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.detail-label {
  color: #999;
  margin-right: 8rpx;
}

.text-warning { color: #FF7D00; }
.text-success { color: #00B42A; }
.text-danger { color: #F53F3F; }

.mt-md { margin-top: 24rpx; }
