/**
 * 请假管理页（教师）样式
 */

.page-container {
  padding-top: 88rpx;
  padding-bottom: 20rpx;
}

/* ===== 自定义导航栏 ===== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: #fff;
  z-index: 100;
  box-sizing: border-box;
}

.nav-back {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  padding: 8rpx 16rpx 8rpx 0;
}

.nav-back-icon {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
}

.nav-placeholder {
  width: 80rpx;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-input {
  flex: 1;
  min-width: 180rpx;
  height: 64rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.filter-picker {
  height: 64rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

/* ===== 统计栏 ===== */
.stats-bar {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* ===== 批量操作 ===== */
.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff0f0;
  margin: 0 24rpx 12rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #F53F3F;
}

.batch-actions {
  display: flex;
  align-items: center;
}

/* ===== 请假卡片 ===== */
.leave-list {
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.leave-card {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
  overflow: hidden;
}

.leave-card-selected {
  background: #e6f4ff;
}

.card-checkbox {
  margin-right: 8rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.checkbox {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  box-sizing: border-box;
}

.checkbox-checked {
  background: #1677FF;
  border-color: #1677FF;
  color: #fff;
}

.card-body {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.card-header-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}

.student-name {
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 160rpx;
}

.card-date-row,
.card-reason,
.card-time {
  overflow: hidden;
}

.card-date-row text,
.card-reason text,
.card-time text {
  font-size: 22rpx;
  line-height: 1.6;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-actions {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 6rpx;
  box-sizing: border-box;
}

.card-actions .btn-sm {
  padding: 6rpx 10rpx;
  font-size: 20rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

/* ===== 对话框 ===== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-box {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.dialog-title {
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-body {
  padding: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.dialog-footer {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 详情行 */
.detail-row {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.detail-label {
  color: #999;
  margin-right: 8rpx;
}

.text-warning { color: #FF7D00; }
.text-success { color: #00B42A; }
.text-danger { color: #F53F3F; }

.mt-sm { margin-top: 12rpx; }
.ml-sm { margin-left: 12rpx; }

/* 分页复用全局样式 */
.pagination {
  justify-content: space-between;
}

.page-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.page-nav .btn-sm {
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  min-width: auto;
  line-height: 1.4;
}

.btn-primary.btn-sm {
  height: 30px;
  line-height: 30px;
  padding-top: 0;
  padding-bottom: 0;
}

.btn-outline.btn-sm {
  width: 162px;
  height: 30px;
  line-height: 30px;
  padding-top: 0;
  padding-bottom: 0;
}

.btn-danger.btn-sm {
  width: 162px;
  height: 30px;
  line-height: 30px;
  padding-top: 0;
  padding-bottom: 0;
}

.page-text {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}
